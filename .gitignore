# ---------------------------------------------------------------------------
# Never commit patient data (PhysioNet DUA).
# MIMIC-IV / eICU raw data, and anything patient-level derived from it, must live
# ONLY in the archive at D:\pythondata\Medical Data. See DATA.md.
# The patterns below are a backstop against it ever being staged by accident.
# ---------------------------------------------------------------------------
data/
*.csv
*.csv.gz
*.parquet
*.feather
*.npz
*.npy
*.pkl
*.pt
*.h5
*.hdf5
*.dta
*.sas7bdat

# Third-party (clone it yourself — see DATA.md)
tools/

# Papers (copyright)
refs/

# Run artifacts
results/
*.log
*_out.txt

# Environment snapshots (local restore only)
.backup/

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.pytest_cache/
*.egg-info/
.venv/
